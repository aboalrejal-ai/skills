{
  "name": "aboalrejal-skills",
  "version": "1.0.0",
  "description": "The ultimate high-performance repository of agentic skills for AI coding assistants.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "validate": "node tools/scripts/run-python.js tools/scripts/plugin_compatibility.py",
    "index": "node tools/scripts/run-python.js tools/scripts/generate_index.py",
    "readme": "node tools/scripts/run-python.js tools/scripts/update_readme.py",
    "app:setup": "node tools/scripts/setup_web.js",
    "app:dev": "npm run app:setup && cd apps/web-app && npm run dev",
    "app:build": "npm run app:setup && cd apps/web-app && npm run build",
    "deploy": "node tools/scripts/deploy.js",
    "chain": "npm run validate && npm run index && npm run readme",
    "sync:all": "npm run chain"
  },
  "dependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/oidc": "^3.6.2",
    "autoprefixer": "^10.5.0",
    "next": "^16.2.9",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "yaml": "^2.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aboalrejal-ai/skills.git"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "gemini-cli",
    "antigravity",
    "agentic-skills",
    "ai-coding"
  ]
}
